rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Transfer file bytes live under `transfers/{batchId}/{fileId}`.
    // A user can read the object if they are the sender or recipient
    // of the matching Firestore transfer doc; only the sender can write.
    // File size is capped at 500MB per object (batch-level ceiling
    // is enforced client-side in TransferDraftValidator).
    match /transfers/{batchId}/{fileId} {
      function transferDoc() {
        return firestore.get(/databases/(default)/documents/transfers/$(batchId)).data;
      }

      allow read: if request.auth != null
                  && (transferDoc().senderUid == request.auth.uid
                      || transferDoc().recipientUid == request.auth.uid);

      allow write: if request.auth != null
                   && transferDoc().senderUid == request.auth.uid
                   && request.resource.size < 500 * 1024 * 1024;

      allow delete: if request.auth != null
                    && (transferDoc().senderUid == request.auth.uid
                        || transferDoc().recipientUid == request.auth.uid);
    }

    // Block everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
