rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public profile document: readable by any authenticated user so
    // recipient lookup can resolve a short code → displayName / isOnline.
    // Sensitive fields (FCM tokens) live in the `private` subcollection below.
    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
                    && request.resource.data.uid == uid;

      allow update: if isSelf(uid)
                    && request.resource.data.uid == uid;

      allow delete: if false;

      // Private subcollection — only the owner can read / write.
      // Cloud Functions use admin SDK which bypasses these rules.
      match /private/{document=**} {
        allow read, write: if isSelf(uid);
      }
    }

    // Short-code registry: code → ownerUid mapping. Reservation is
    // transactional from the client; rules guard ownership.
    match /codes/{code} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.shortCode == code;

      allow update: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == request.auth.uid;

      allow delete: if false;
    }

    // Transfer control plane: a transfer doc is readable / writable only by
    // its sender or recipient. Create is restricted to sender; accept /
    // reject / cancel / progress updates are enforced by the client-side
    // transactions and the narrower constraints below.
    match /transfers/{batchId} {
      function isParticipant() {
        return isSignedIn()
               && (resource.data.senderUid == request.auth.uid
                   || resource.data.recipientUid == request.auth.uid);
      }

      allow read: if isSignedIn()
                  && (resource.data.senderUid == request.auth.uid
                      || resource.data.recipientUid == request.auth.uid);

      allow create: if isSignedIn()
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.recipientUid is string
                    && request.resource.data.recipientUid.size() > 0;

      allow update: if isParticipant();

      allow delete: if false;
    }
  }
}
